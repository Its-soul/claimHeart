# ============================================
# ClaimHeart Backend Environment Configuration
# ============================================

# ── Application ──
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_HOST=0.0.0.0

# ── GROQ API Keys (Load Balancing) ──
# Provide 4 keys for load balancing and fallback
GROQ_API_KEY_1=your_groq_api_key_1_here
GROQ_API_KEY_2=your_groq_api_key_2_here
GROQ_API_KEY_3=your_groq_api_key_3_here
GROQ_API_KEY_4=your_groq_api_key_4_here

# Default Groq model to use
GROQ_MODEL=llama-3.3-70b-versatile

# ── Database ──
DATABASE_URL=postgresql://claimheart:claimheart_password@localhost:5432/claimheart_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis (Task Queue & Caching) ──
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ── JWT Authentication ──
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS Origins ──
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# ── File Upload ──
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=temp_uploads

# ── OCR Configuration ──
OCR_ENGINE=easyocr
OCR_LANGUAGES=en
TESSERACT_PATH=/usr/bin/tesseract

# ── RAG Configuration ──
RAG_STORAGE_PATH=./app/data/chroma_store
RAG_COLLECTION_NAME=claimheart_embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Fraud Detection ──
FRAUD_CONFIDENCE_THRESHOLD=0.65
FRAUD_RISK_THRESHOLD=45

# ── Logging ──
LOG_LEVEL=INFO
LOG_FILE=logs/claimheart.log

# ── External Services (Optional) ──
SENTRY_DSN=
SLACK_WEBHOOK_URL=
